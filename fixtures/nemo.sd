@position unit_labor_costs 641 1237
@position business_rate 2280 1539
@position debt_service_bus 2375 1598
@position business_costs 2504 1621
@position housing_demand 2041 197
@position construction_activity 2131 197
@position rent_inflation 2221 197
@position municipal_rate 1354 494
@position debt_service_muni 1423 417
@position municipal_services 1567 454
