@type id

@location-types
  aws orange
  azure blue
  gcp green
  on-prem grey

@flow-types
  sync solid
  async dashed
  batch thick

system   WebApp      [aws]
system   ApiSvc      [azure]
system   AuthSvc     [gcp]
database CustomerDB  [on-prem]
queue    EventQueue  [aws]

connect  WebApp    ->   ApiSvc     : REST [flow:sync]
connect  WebApp    ->   AuthSvc    : REST [flow:sync]
connect  ApiSvc    ->   CustomerDB : JDBC [flow:sync]
connect  ApiSvc    ->   EventQueue : SQS [flow:async]
